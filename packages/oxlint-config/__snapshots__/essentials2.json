{
  "plugins": ["oxc"],
  "categories": {},
  "rules": {
    "accessor-pairs": "allow",
    "array-callback-return": "deny",
    "arrow-body-style": "deny",
    "block-scoped-var": "deny",
    "capitalized-comments": "allow",
    "class-methods-use-this": "allow",
    "complexity": "allow",
    "constructor-super": "deny",
    "curly": "deny",
    "default-case": "allow",
    "default-case-last": "deny",
    "default-param-last": "deny",
    "eqeqeq": "deny",
    "for-direction": "deny",
    "func-name-matching": "allow",
    "func-names": "deny",
    "func-style": "allow",
    "getter-return": "deny",
    "grouped-accessor-pairs": "deny",
    "guard-for-in": "deny",
    "id-length": "allow",
    "init-declarations": "allow",
    "logical-assignment-operators": "deny",
    "max-classes-per-file": "allow",
    "max-depth": "allow",
    "max-lines": "allow",
    "max-lines-per-function": "allow",
    "max-nested-callbacks": "allow",
    "max-params": "allow",
    "max-statements": "allow",
    "new-cap": "deny",
    "no-alert": "deny",
    "no-array-constructor": "deny",
    "no-async-promise-executor": "deny",
    "no-await-in-loop": "deny",
    "no-bitwise": "allow",
    "no-caller": "deny",
    "no-case-declarations": "deny",
    "no-class-assign": "deny",
    "no-compare-neg-zero": "deny",
    "no-cond-assign": "deny",
    "no-console": "warn",
    "no-const-assign": "deny",
    "no-constant-binary-expression": "deny",
    "no-constant-condition": "deny",
    "no-constructor-return": "deny",
    "no-continue": "deny",
    "no-control-regex": "deny",
    "no-debugger": "deny",
    "no-delete-var": "deny",
    "no-div-regex": "allow",
    "no-dupe-class-members": "deny",
    "no-dupe-else-if": "deny",
    "no-dupe-keys": "deny",
    "no-duplicate-case": "deny",
    "no-duplicate-imports": "allow",
    "no-else-return": "deny",
    "no-empty": "deny",
    "no-empty-character-class": "deny",
    "no-empty-function": "deny",
    "no-empty-pattern": "deny",
    "no-empty-static-block": "deny",
    "no-eq-null": "allow",
    "no-eval": "deny",
    "no-ex-assign": "deny",
    "no-extend-native": "deny",
    "no-extra-bind": "deny",
    "no-extra-boolean-cast": "deny",
    "no-extra-label": "deny",
    "no-fallthrough": "deny",
    "no-func-assign": "deny",
    "no-global-assign": "deny",
    "no-implicit-coercion": "deny",
    "no-import-assign": "deny",
    "no-inline-comments": "allow",
    "no-inner-declarations": "deny",
    "no-invalid-regexp": "deny",
    "no-irregular-whitespace": "deny",
    "no-iterator": "deny",
    "no-label-var": "deny",
    "no-labels": "deny",
    "no-lone-blocks": "deny",
    "no-lonely-if": "deny",
    "no-loop-func": "deny",
    "no-loss-of-precision": "deny",
    "no-magic-numbers": "allow",
    "no-misleading-character-class": "deny",
    "no-multi-assign": "deny",
    "no-multi-str": "deny",
    "no-negated-condition": "allow",
    "no-nested-ternary": "allow",
    "no-new": "deny",
    "no-new-func": "deny",
    "no-new-native-nonconstructor": "deny",
    "no-new-wrappers": "deny",
    "no-nonoctal-decimal-escape": "deny",
    "no-obj-calls": "deny",
    "no-object-constructor": "deny",
    "no-param-reassign": "deny",
    "no-plusplus": "deny",
    "no-promise-executor-return": "deny",
    "no-proto": "deny",
    "no-prototype-builtins": "deny",
    "no-redeclare": "allow",
    "no-regex-spaces": "deny",
    "no-restricted-globals": "deny",
    "no-restricted-imports": "deny",
    "no-restricted-properties": "deny",
    "no-return-assign": "deny",
    "no-script-url": "deny",
    "no-self-assign": "deny",
    "no-self-compare": "deny",
    "no-sequences": "deny",
    "no-setter-return": "deny",
    "no-shadow": "allow",
    "no-shadow-restricted-names": "deny",
    "no-sparse-arrays": "deny",
    "no-template-curly-in-string": "deny",
    "no-ternary": "allow",
    "no-this-before-super": "deny",
    "no-throw-literal": "deny",
    "no-unassigned-vars": "deny",
    "no-undefined": "allow",
    "no-underscore-dangle": "deny",
    "no-unexpected-multiline": "deny",
    "no-unmodified-loop-condition": "allow",
    "no-unneeded-ternary": "deny",
    "no-unreachable": "deny",
    "no-unsafe-finally": "deny",
    "no-unsafe-negation": "deny",
    "no-unsafe-optional-chaining": "deny",
    "no-unused-expressions": "deny",
    "no-unused-labels": "deny",
    "no-unused-private-class-members": "allow",
    "no-unused-vars": "deny",
    "no-use-before-define": "allow",
    "no-useless-backreference": "deny",
    "no-useless-call": "allow",
    "no-useless-catch": "deny",
    "no-useless-computed-key": "deny",
    "no-useless-concat": "deny",
    "no-useless-constructor": "deny",
    "no-useless-escape": "deny",
    "no-useless-rename": "deny",
    "no-useless-return": "deny",
    "no-var": "deny",
    "no-void": "deny",
    "no-warning-comments": "allow",
    "no-with": "deny",
    "object-shorthand": "deny",
    "operator-assignment": "deny",
    "prefer-const": "deny",
    "prefer-destructuring": "deny",
    "prefer-exponentiation-operator": "deny",
    "prefer-numeric-literals": "deny",
    "prefer-object-has-own": "deny",
    "prefer-object-spread": "deny",
    "prefer-promise-reject-errors": "allow",
    "prefer-rest-params": "deny",
    "prefer-spread": "deny",
    "prefer-template": "deny",
    "preserve-caught-error": "deny",
    "radix": "deny",
    "require-await": "allow",
    "require-unicode-regexp": "allow",
    "require-yield": "deny",
    "sort-imports": "allow",
    "sort-keys": "allow",
    "sort-vars": "allow",
    "symbol-description": "deny",
    "unicode-bom": "deny",
    "use-isnan": "deny",
    "valid-typeof": "deny",
    "vars-on-top": "deny",
    "yoda": "deny",
    "oxc/approx-constant": "deny",
    "oxc/bad-array-method-on-arguments": "deny",
    "oxc/bad-bitwise-operator": "deny",
    "oxc/bad-char-at-comparison": "deny",
    "oxc/bad-comparison-sequence": "deny",
    "oxc/bad-min-max-func": "deny",
    "oxc/bad-object-literal-comparison": "deny",
    "oxc/bad-replace-all-arg": "deny",
    "oxc/branches-sharing-code": "deny",
    "oxc/const-comparisons": "deny",
    "oxc/double-comparisons": "deny",
    "oxc/erasing-op": "deny",
    "oxc/misrefactored-assign-op": "deny",
    "oxc/missing-throw": "deny",
    "oxc/no-accumulating-spread": "deny",
    "oxc/no-async-await": "deny",
    "oxc/no-async-endpoint-handlers": "deny",
    "oxc/no-barrel-file": "deny",
    "oxc/no-const-enum": "deny",
    "oxc/no-map-spread": "deny",
    "oxc/no-optional-chaining": "deny",
    "oxc/no-rest-spread-properties": "deny",
    "oxc/no-this-in-exported-function": "deny",
    "oxc/number-arg-out-of-range": "deny",
    "oxc/only-used-in-recursion": "deny",
    "oxc/uninvoked-array-callback": "deny"
  },
  "settings": {
    "jsx-a11y": {
      "polymorphicPropName": null,
      "components": {},
      "attributes": {}
    },
    "next": {
      "rootDir": []
    },
    "react": {
      "formComponents": [],
      "linkComponents": [],
      "version": null,
      "componentWrapperFunctions": []
    },
    "jsdoc": {
      "ignorePrivate": false,
      "ignoreInternal": false,
      "ignoreReplacesDocs": true,
      "overrideReplacesDocs": true,
      "augmentsExtendsReplacesDocs": false,
      "implementsReplacesDocs": false,
      "exemptDestructuredRootsFromChecks": false,
      "tagNamePreference": {}
    },
    "vitest": {
      "typecheck": false
    },
    "jest": {
      "version": null
    }
  },
  "env": {
    "builtin": true,
    "es2024": true
  },
  "globals": {},
  "ignorePatterns": ["**/bin/*", "**/build/*", "**/dist/*", "**/node_modules/*"]
}
