{
  "name": "@wakamsha/oxlint-config",
  "version": "1.0.3",
  "description": "wakamsha's oxlint rules as an extensible shared config.",
  "exports": {
    ".": {
      "import": "./configs/index.ts"
    },
    "./configs/*.json": "./configs/*.json",
    "./configs/test/*.json": "./configs/test/*.json"
  },
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "files": [
    "configs",
    "rules-json",
    "src"
  ],
  "scripts": {
    "generate:configs-json": "node ./scripts/generateConfigsJson.ts && prettier --write './configs/**/*.json'",
    "generate:rules-json": "  node ./scripts/generateRulesJson.ts   && prettier --write ./rules-json",
    "release": "semantic-release"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wakamsha/frontend-tools.git",
    "directory": "packages/oxlint-config"
  },
  "keywords": [
    "oxlint",
    "oxlint-config",
    "lint",
    "typescript"
  ],
  "author": "wakamsha <wakamsha@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wakamsha/frontend-tools/issues"
  },
  "homepage": "https://github.com/wakamsha/frontend-tools/tree/main/packages/oxlint-config#readme",
  "devDependencies": {
    "@types/node": "24.12.2",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "prettier": "3.8.3",
    "release-config": "workspace:*",
    "semantic-release": "25.0.3"
  },
  "peerDependencies": {
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0"
  }
}
