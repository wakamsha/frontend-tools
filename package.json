{
  "name": "frontend-tools",
  "description": "wakamsha's frontend tools as an extensible shared config.",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.14.0",
    "pnpm": "10.30.3",
    "npm": "please use pnpm instead"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "prepare": "lefthook install",
    "format": "pnpm prettier -w './**/*.{js,ts,json,md,css,html}'",
    "eslint-config": "   pnpm -F '@wakamsha/eslint-config'",
    "oxlint-config": "   pnpm -F '@wakamsha/oxlint-config'",
    "stylelint-config": "pnpm -F '@wakamsha/stylelint-config'"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wakamsha/frontend-tools.git"
  },
  "author": "wakamsha <wakamsha@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wakamsha/frontend-tools/issues"
  },
  "homepage": "https://github.com/wakamsha/frontend-tools#readme",
  "pnpm": {
    "overrides": {
      "@typescript-eslint/utils": ">=8.46.0"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.3",
    "@commitlint/config-conventional": "20.4.3",
    "cspell": "9.7.0",
    "lefthook": "2.1.2",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0"
  }
}
